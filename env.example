# ===========================================
# EVOMETRICS - ENVIRONMENT VARIABLES
# ===========================================
# Copia questo file come .env e compila i valori
# Per Render.com: aggiungi queste variabili nel dashboard

# ===========================================
# BASE CONFIGURATION
# ===========================================
# URL completo del webhook ClickFunnel (es. https://www.evoluzioneimprese.com/webhook/clickfunnels)
# ⚠️ Configura questo URL nelle impostazioni webhook di ClickFunnel
CLICKFUNNEL_WEBHOOK_URL=https://www.evoluzioneimprese.com/webhook/clickfunnels

# Stage iniziale per i lead creati da ClickFunnel (default: "optin")
# ⚠️ Deve corrispondere a uno stage esistente nella pipeline
CLICKFUNNEL_INITIAL_STAGE=optin

PORT=10000
BASE_URL=https://www.evoluzioneimprese.com
FRONTEND_URL=https://www.evoluzioneimprese.com
UNIFIED_MODE=true
RENDER=true

# ===========================================
# DATABASE
# ===========================================
# ⚠️ OBBLIGATORIO: Database PostgreSQL principale
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Database per Sales Pipeline (opzionale)
# Se non configurato: usa DATABASE_URL principale (PostgreSQL condiviso con altri servizi)
# Se configurato: usa questo database specifico (override, utile per database separato se necessario)
# Esempio: postgresql://user:password@host:5432/sales_db
# SALES_DATABASE_URL=

# Database SQLite per calendar-service
# ⚠️ In produzione (RENDER=true), questa variabile è OBBLIGATORIA
# In sviluppo, se non configurata usa default: calendar.db nella directory del servizio
CALENDAR_DATABASE_URL=sqlite:///./calendar.db

# ===========================================
# AUTHENTICATION & SECURITY
# ===========================================
# 🔒 CRITICHE PER SICUREZZA - OBBLIGATORIE, MAI HARDCODATE
# ⚠️ Queste variabili NON devono mai avere default nel codice
SECRET_KEY=your-super-secret-key-min-32-chars
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars
SERVICE_TOKEN=genera-un-token-casuale-sicuro-min-32-caratteri
ENCRYPTION_KEY=your-encryption-key-base64
ENCRYPTION_SALT=your-encryption-salt

# ===========================================
# GOOGLE OAUTH & SERVICES
# ===========================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://www.evoluzioneimprese.com/api/auth/google/callback
# Google OAuth URIs (opzionali, hanno fallback ai valori standard Google)
# ⚠️ Normalmente non necessario modificarli, a meno di usare endpoint custom
GOOGLE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
GOOGLE_TOKEN_URI=https://oauth2.googleapis.com/token
GOOGLE_USERINFO_URI=https://www.googleapis.com/oauth2/v2/userinfo

# Google Calendar Scopes (CSV, opzionale, ha fallback standard)
# ⚠️ Normalmente non necessario modificarli, a meno di richiedere scope aggiuntivi
GOOGLE_CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar.events,https://www.googleapis.com/auth/calendar.readonly,https://www.googleapis.com/auth/userinfo.email
GOOGLE_SERVICE_ACCOUNT_JSON={"type": "service_account", ...}

# ===========================================
# INTERNAL SERVICE URLs (Unified Mode)
# ===========================================
# In unified mode, questi URL sono usati solo per fallback o chiamate HTTP esplicite
# Possono essere omessi se UNIFIED_MODE=true (default)
PREVENTIVI_SERVICE_URL=https://www.evoluzioneimprese.com
CONTRATTI_SERVICE_URL=https://www.evoluzioneimprese.com
CLIENTI_SERVICE_URL=https://www.evoluzioneimprese.com
PRODUCTIVITY_SERVICE_URL=https://www.evoluzioneimprese.com
USER_SERVICE_URL=https://www.evoluzioneimprese.com
GATEWAY_URL=https://www.evoluzioneimprese.com
EMAIL_SERVICE_URL=https://www.evoluzioneimprese.com

# ===========================================
# DATABASE POOL CONFIGURATION
# ===========================================
# ⚠️ Opzionali: hanno default (1, 3) ma possono essere configurati per ottimizzazione
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=3

# ===========================================
# CALENDAR SERVICE CONFIGURATION
# ===========================================
# ⚠️ Opzionali: hanno default ma possono essere configurati
DEFAULT_TIMEZONE=Europe/Rome
DEFAULT_NOTIFICATION_MINUTES=30

# ===========================================
# EMAIL CONFIGURATION
# ===========================================
EMAIL_PROVIDER=resend
ENABLE_EMAIL=true
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=info@evoluzioneimprese.com
RESEND_FROM_NAME=Evoluzione Imprese

# SMTP (alternativa a Resend, se SMTP_ENABLED=true)
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=info@evoluzioneimprese.com
SMTP_FROM_NAME=Evoluzione Imprese
SMTP_USE_TLS=false
SMTP_USE_STARTTLS=true

# ===========================================
# SHOPIFY INTEGRATION
# ===========================================
SHOPIFY_API_KEY=your-shopify-api-key
SHOPIFY_API_SECRET=your-shopify-api-secret
SHOPIFY_ENCRYPTION_KEY=your-shopify-encryption-key
SHOPIFY_SCOPES=read_orders,read_products,read_customers,read_analytics

# ===========================================
# SIBILL INTEGRATION
# ===========================================
SIBILL_API_URL=https://integration.sibill.com
SIBILL_API_KEY=your-sibill-api-key
SIBILL_COMPANY_ID=your-company-id

# ===========================================
# EXTERNAL SERVICES
# ===========================================
N8N_WEBHOOK_ASSESSMENT=https://your-n8n-webhook-url
N8N_WEBHOOK_ONBOARDING=https://your-n8n-webhook-url
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4
CLICKUP_API_KEY=your-clickup-api-key
MAILCHIMP_API=your-mailchimp-api-key

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_PER_HOUR=2000

# ===========================================
# ADMIN CONFIGURATION
# ===========================================
ADMIN_EMAIL=admin@evoluzioneimprese.com
API_KEY=your-api-key

# ===========================================
# FRONTEND ENVIRONMENT VARIABLES (Vite)
# ===========================================
# Queste variabili devono essere prefissate con VITE_ per essere accessibili nel frontend
# In Render.com, aggiungi queste come variabili d'ambiente del servizio
VITE_API_GATEWAY_URL=https://www.evoluzioneimprese.com
VITE_PORT=5173
VITE_API_URL=https://www.evoluzioneimprese.com

# Opzionali (per override specifici servizi)
VITE_USER_SERVICE_URL=https://www.evoluzioneimprese.com
VITE_CLIENTI_SERVICE_URL=https://www.evoluzioneimprese.com
VITE_SALES_SERVICE_URL=https://www.evoluzioneimprese.com
VITE_PRODUCTIVITY_SERVICE_URL=https://www.evoluzioneimprese.com
VITE_PREVENTIVI_SERVICE_URL=https://www.evoluzioneimprese.com
VITE_CONTRATTI_SERVICE_URL=https://www.evoluzioneimprese.com

# ===========================================
# NOTES
# ===========================================
# - In produzione (Render.com), tutte le variabili VITE_* vengono sostituite
#   durante il build del frontend
# - Le variabili senza VITE_ sono solo per il backend
# - In unified mode (UNIFIED_MODE=true), i servizi comunicano direttamente
#   senza HTTP, quindi gli URL interni sono usati solo come fallback
#
# ===========================================
# SICUREZZA
# ===========================================
# 🔒 Variabili Critiche (OBBLIGATORIE, no default):
#    - SECRET_KEY, JWT_SECRET_KEY, SERVICE_TOKEN
#    - GOOGLE_CLIENT_SECRET, SHOPIFY_API_SECRET
#    - Tutte le API keys (RESEND, SIBILL, OPENAI, etc.)
#    - ENCRYPTION_KEY, ENCRYPTION_SALT
#
# ⚠️ Variabili Importanti (OBBLIGATORIE in produzione):
#    - DATABASE_URL, BASE_URL, FRONTEND_URL
#    - SALES_DATABASE_URL, CALENDAR_DATABASE_URL (in produzione)
#
# 🔧 Variabili Opzionali (hanno default sensati):
#    - DB_POOL_MIN_SIZE, DB_POOL_MAX_SIZE
#    - DEFAULT_TIMEZONE, DEFAULT_NOTIFICATION_MINUTES
#    - GOOGLE_AUTH_URI, GOOGLE_TOKEN_URI (fallback standard)
#
# Vedi SECURITY_GUIDELINES.md per dettagli completi
